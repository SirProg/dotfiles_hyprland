{
	// Modules left
	"hyprland/window":{
		"max-length": 60,
		"rewrite": {
			"(.*) - kitty": "´äá  [$1]",
			"(.*) - Mozilla Firefox": "´ëę $1"
		},
		"separate-outputs": true
	},
	
	// Modules Center
	"hyprland/workspaces": {
		"on-scroll-up": "hyprctl dispatch workspace r-1",
		"on-scroll-down": "hyprctl dispatch workspace r+1",
		"on-click": "activate",
		"active-only": true,
		"format": "{}",
		"format-icons": {
			"urgent": "",
			"active": "",
			"default": ""
		},
		"persistent-workspaces": {
			"*": 7
		}
	},


	// Modules Right
	
	//Search with wofi
	"custom/search": {
		"format": "{icon} search",
		"format-icons": {"default": "´Çé"},
		"on-click": "wofi --show drun"		
	},
	

	// PulseAudio
		
	"pulseaudio":{
		"format": "{icon} {volume}%",
		"format-bluetooth": "{volume}% {icon}´Őö {format_source}",
		"format-bluetooth-muted": "´Üę {icon}´Őö {format_source}",
		"format-muted": "´Üę {format_source}",
		"format-source": "{volume}% ´ä░",
		"format-source-muted": "{volume}% ´ä▒ ",
		"format-icons":{
			"headphone": "´Çą ",
			"hands-free": "´ľÉ ",
			"headset": "´ľÉ ",
			"phone": "´éĽ ",
			"portable": "´éĽ",
			"car": "´ć╣ ",
			"default": [
				"´ÇŽ",
				"´Çž ",
				"´ÇĘ "
			]	
		}, 
		"on-click": "pavucontrol"
	},
	
	//Bluetooth
	"custom/bluetooth": {
		"exec": "~/.config/waybar/scripts/bluetooth-status.sh",
		"interval": 5,
		"on-click": "blueman-manager",
		"tooltip": true,
		"format": {}
	},

	// Network
	"network": {
    		"format-wifi": "´çź  {essid}({signalStrength}%)",
    		"format-ethernet": "´×ľ {ipaddr}",
    		"format-disconnected": "´ü▒ Desconectado",
    		"tooltip-format": "{ifname}: {ipaddr}/{cidr} ÔÇó {gwaddr}"
  	},

	//Battery
	"battery": {
    		"interval": 1,
    		"states": {
      			"good": 80,
      			"warning": 30,
      			"critical": 15
    		},
    		"format": "{icon} {capacity}%",
    		"format-charging": "´Śž  {capacity}%",
    		"format-plugged": "´çŽ  {capacity}%",
    		"format-alt": "{icon}  {time}",
    		"format-icons": [
      			"´ëä ",
      			"´ëâ ",
      			"´ëé ",
      			"´ëü ",
      			"´ëÇ "
    		]
  	},

	// Group Hardware
	"group/hardware": {
		"orientation": "inherit",
    		"drawer": {
      			"transition-duration": 300,
      			"children-class": "not-memory",
      			"transition-left-to-right": false
    		},
    		"modules": [
      			"disk",
      			"cpu",
      			"memory"
    		]
  	},	
	
	//Disk
	"disk": {
    		"interval": 30,
    		"format": "´éá D {percentage_used}% "
    	},		
	
	//CPU
	"cpu": {
    		"format": "´äë / C {usage}% "
    	},

	//Memory
	"memory": {
    		"format": "´öŞ / M {}% "
  	},


	//Exit
	"custom/exit": {
		"format": "´ÇĹ", // Icono de apagado (Font Awesome)
		"on-click": "~/.config/waybar/scripts/powermenu/powermenu.sh",
  		"tooltip": true,
  		"tooltip-format": "Men├║ de apagado"
	}
		
}
